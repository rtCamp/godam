{
	"root": true,
	"extends": [
	  "plugin:@wordpress/eslint-plugin/recommended-with-formatting",
	  "plugin:import/recommended",
	  "plugin:eslint-comments/recommended"
	],
	"env": {
	  "browser": true
	},
	"rules": {
	  "jsdoc/check-indentation": "error",
	  "@wordpress/dependency-group": "error"
	},
	"overrides": [{
	  "files": [
		"**/__tests__/**/*.js",
		"**/test/*.js",
		"**/?(*.)test.js",
		"tests/js/**/*.js"
	  ],
	  "extends": [
		"plugin:jest/recommended"
	  ],
	  "rules": {
		// Add stricter Jest rules here as the suite grows. `jest/recommended`
		// (the baseline @wordpress/scripts uses) avoids `jest/all`'s pedantic
		// rules and its `unbound-method`, which needs TS parser services this
		// JS project doesn't configure.
	  }
	}]
  }
  